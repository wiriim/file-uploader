<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>File Uploader</title>
    </head>
    <body>
        <h1>File Uploader</h1>
        <nav>
            <% if (!locals.currentUser) { %>
                <a href="/login">Login</a>
                <a href="/signup">Sign Up</a>
            <% } else { %>
                <p><%= currentUser.username %></p>
                <a href="/logout">Logout</a>
            <% } %>
        </nav>
    </body>
</html>
